<script>
// ── CHECKLIST ──────────────────────────────────────────────────────────────
const TOTAL_TASKS = 8;
let tasks = JSON.parse(localStorage.getItem('sw_onboarding') || '[]');

const progressEmojis  = ['🌱','🌿','🌳','⭐','🌟','💪','🏆','🎉'];
const progressLabels  = ['Just getting started!','Good start — keep going!','Making great progress!','Halfway there!','More than halfway done!','Almost there!','One last step!','You\'re all set! 🎉'];
const progressSubs    = [
  'Complete tasks above to track your onboarding.',
  'Keep checking off tasks to complete your setup.',
  'You\'re getting the hang of it!',
  'Four down, four to go.',
  'The finish line is in sight.',
  'Nearly done with your store setup.',
  'Complete the last task to finish onboarding.',
  'Your store is fully configured and ready to go.'
];

function renderChecklist() {
  tasks.forEach((done, i) => {
    const card = document.querySelector(`[data-task="${i}"]`);
    const box  = document.getElementById(`cb${i}`);
    if (!card || !box) return;
    card.classList.toggle('done', done);
    box.textContent = done ? '✓' : '';
  });
  const count = tasks.filter(Boolean).length;
  const pct   = Math.round(count / TOTAL_TASKS * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressPct').textContent  = pct + '%';
  document.getElementById('progressEmoji').textContent = progressEmojis[count] || '🎉';
  document.getElementById('progressLabel').textContent = progressLabels[count] || 'Complete!';
  document.getElementById('progressSub').textContent   = progressSubs[count]   || '';
  // Show sticky progress after first interaction
  if (count > 0) document.getElementById('stickyProgress').style.display = 'block';
}

function toggleTask(i) {
  if (tasks.length < TOTAL_TASKS) tasks = Array(TOTAL_TASKS).fill(false);
  tasks[i] = !tasks[i];
  localStorage.setItem('sw_onboarding', JSON.stringify(tasks));
  renderChecklist();
}

if (tasks.length < TOTAL_TASKS) tasks = Array(TOTAL_TASKS).fill(false);
renderChecklist();

// ── VIDEO MODULES ──────────────────────────────────────────────────────────
const modules = [
  { num:'01', icon:'🏪', bg:'#e6f7f9', title:'App Overview & First Login', desc:'Tour the app, understand the layout, and set up your PIN for the first time.', duration:'5 min', tag:'beginner', tagLabel:'Beginner', videoUrl:null },
  { num:'02', icon:'📦', bg:'#f0e8ff', title:'Inventory Management', desc:'Add, edit, and delete products. Set stock levels, categories, and suppliers.', duration:'8 min', tag:'beginner', tagLabel:'Beginner', videoUrl:null },
  { num:'03', icon:'💳', bg:'#e8f8f0', title:'Sales & POS Walkthrough', desc:'Process a sale from start to finish. Handle cash and card payments.', duration:'6 min', tag:'staff', tagLabel:'Staff', videoUrl:null },
  { num:'04', icon:'📈', bg:'#fff3e0', title:'Analytics & Reporting', desc:'Read your performance metrics, spot trends, and understand top products.', duration:'7 min', tag:'owner', tagLabel:'Owner', videoUrl:null },
  { num:'05', icon:'☁️', bg:'#fef7e8', title:'Cloud Sync Setup', desc:'Connect Google Drive, Dropbox, or a local file to keep your data backed up.', duration:'10 min', tag:'owner', tagLabel:'Owner', videoUrl:null },
  { num:'06', icon:'🔐', bg:'#fce8e8', title:'Security & PIN Management', desc:'Understand encryption, change your PIN, and set up auto-lock.', duration:'5 min', tag:'advanced', tagLabel:'Advanced', videoUrl:null },
];

document.getElementById('modulesGrid').innerHTML = modules.map((m,i) => `
  <div class="module-card" onclick="openVideo(${i})">
    <div class="module-thumb" style="background:${m.bg}">${m.icon}</div>
    <div class="module-body">
      <div class="module-num">Module ${m.num}</div>
      <div class="module-title">${m.title}</div>
      <div class="module-desc">${m.desc}</div>
      <div class="module-meta">
        <span class="module-duration">⏱ ${m.duration}</span>
        <span class="module-tag tag-${m.tag}">${m.tagLabel}</span>
      </div>
    </div>
  </div>`).join('');

function openVideo(i) {
  const m = modules[i];
  document.getElementById('modalIcon').textContent = m.icon;
  document.getElementById('modalTitle').textContent = m.title;
  document.getElementById('modalDesc').textContent  = m.desc;
  document.getElementById('videoModal').classList.add('open');
}
function closeVideo() {
  document.getElementById('videoModal').classList.remove('open');
}
document.getElementById('videoModal').addEventListener('click', e => {
  if (e.target.id === 'videoModal') closeVideo();
});

// ── GUIDE TABS ─────────────────────────────────────────────────────────────
function switchTab(id) {
  document.querySelectorAll('.guide-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.guide-panel').forEach(p => p.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('panel-' + id).classList.add('active');
}

// ── FAQ ────────────────────────────────────────────────────────────────────
const faqs = [
  { q:'What happens if I forget my PIN?', a:'On the lock screen, tap "Forgot PIN? Reset all data." This deletes all encrypted data and lets you start fresh. This is why connecting cloud sync (Google Drive, Dropbox) and doing regular exports is so important — those are your backups.' },
  { q:'Is my data ever sent to a server?', a:'No. StoreWise runs 100% in your browser. Data lives in your browser\'s localStorage and, if you connect sync, in your own Google Drive or Dropbox account. No third-party server ever receives your data.' },
  { q:'Can I use the app on multiple devices?', a:'Yes — connect Google Drive or Dropbox sync on each device using the same account. When you make changes on one device and open the app on another, load the latest data using the "Load from Drive/Dropbox" button in Settings → Data Sync.' },
  { q:'What does the Local File sync do exactly?', a:'It saves an encrypted .enc file to a location you choose on your computer (Documents, USB drive, Dropbox folder, etc.) and updates it automatically every time you make a change. This only works in Chrome and Edge due to browser security restrictions.' },
  { q:'Can my staff access the app?', a:'Yes. Share the app URL with staff. Each person will be prompted to create their own PIN on first use. If you want a single shared PIN for all staff, you can set one PIN and share it — but note that whoever forgets the PIN loses access.' },
  { q:'How do I add my logo or customize the app name?', a:'Open index.html and change the store name in the Settings panel, or edit the HTML directly. The sidebar shows the store name from your Settings → Store Settings → Store Name field.' },
  { q:'Why does the File System sync only work in Chrome/Edge?', a:'The File System Access API is a relatively new browser feature not yet supported in Firefox or Safari. For those browsers, use Google Drive or Dropbox sync instead.' },
  { q:'How do I update the app when a new version is released?', a:'Since the app is hosted on GitHub Pages, just pull the latest files from the repository and push them. Your data in localStorage (and cloud sync) is separate from the app code, so updates never overwrite your data.' },
];

document.getElementById('faqList').innerHTML = faqs.map((f,i) => `
  <div class="faq-item" id="faq${i}">
    <div class="faq-q" onclick="toggleFAQ(${i})">${f.q}<span class="faq-icon">+</span></div>
    <div class="faq-a"><div class="faq-a-inner">${f.a}</div></div>
  </div>`).join('');

function toggleFAQ(i) {
  document.getElementById('faq'+i).classList.toggle('open');
}

// ── FADE IN ON SCROLL ──────────────────────────────────────────────────────
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
</script>
